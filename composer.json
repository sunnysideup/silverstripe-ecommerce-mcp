{
  "name": "sunnysideup/ecommerce-mcp",
  "description": "Allows LLM Agents to get information from your shop using the MCP Protocol",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "mcp",
    "ecommerce",
    "llm",
    "ai",
    "brave new world",
    "no human in the middle"
  ],
  "license": "BSD-3-Clause",
  "require": {
    "silverstripe/framework": "^5.0",
    "silverstripe/admin": "^2.0"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "5.x-dev",
    "silverleague/ideannotator": "*",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7",
    "silverstripe/standards": "^1",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Sunnysideup\\EcommerceMCP\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "client/dist"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "bin": [
    "bin/sake-npm-build-ecommerce-mcp.sh",
    "bin/sake-npm-watch-ecommerce-mcp.sh"
  ],
  "authors": [
    {
      "name": "Nicolaas Thiemen Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ]
}
